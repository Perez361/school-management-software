{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchoolDesk",
  "version": "0.1.0",
  "identifier": "com.adahigh.sms",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SchoolDesk — School Management System",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:3000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "server/**/*": "server/",
      "../.next/**/*": ".next/",
      "../node_modules/.prisma/**/*": "node_modules/.prisma/",
      "../prisma/schema.prisma": "prisma/schema.prisma",
      "../school.db": "school.db"
    },
    "externalBin": [
      "binaries/node"
    ]
  }
}