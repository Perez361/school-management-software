NEXT_PUBLIC_DEMO_MODE=true

# JWT secret for the Axum HTTP API server (browser / WiFi mode).
# Set SMS_JWT_SECRET in the OS environment before launching the app.
# Generate one with: openssl rand -hex 32
# This file is read by Next.js only — Rust reads it from the OS environment.
# SMS_JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
